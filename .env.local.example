# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Google Gemini (AI analysis) ───────────────────────────────────────────────
# GOOGLE_CLOUD_PROJECT: your GCP project ID (e.g. my-project-123456)
# GOOGLE_SERVICE_ACCOUNT_JSON: the full service account JSON, compacted to ONE line
#
# How to compact the JSON:
#
# Mac / Linux:
#   python3 -c "import json,sys; print(json.dumps(json.load(open('/path/to/key.json'))))"
#
# Windows (PowerShell):
#   $j = Get-Content 'C:\path\to\key.json' -Raw
#   ($j | ConvertFrom-Json | ConvertTo-Json -Compress -Depth 100)
#
# Paste the single-line output as the value below. No newlines, no quotes around it.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── Email reports (optional) ──────────────────────────────────────────────────
# Get from: resend.com -> API Keys -> Create API Key
# Without this, scans work but email reports are silently skipped.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ── App URL ───────────────────────────────────────────────────────────────────
# Used to build links in email reports.
# Keep as http://localhost:3000 for local dev.
# Update to your Vercel URL after deploying (e.g. https://contract-scanner-xyz.vercel.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000
